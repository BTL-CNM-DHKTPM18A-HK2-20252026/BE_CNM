# ===================================
# FRUVIA BACKEND ENVIRONMENT VARIABLES - EXAMPLE
# ===================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git

# ===== DATABASE CONFIGURATION =====
# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=fruvia_db
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ===== REDIS CONFIGURATION =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000ms

# ===== JWT CONFIGURATION =====
# Generate a strong random key for production: openssl rand -base64 64
JWT_SIGNER_KEY=your-secret-key-here-change-this-in-production
JWT_EXPIRATION=2592000

# ===== EMAIL CONFIGURATION =====
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=noreply@fruvia.app
OTP_TTL_MINUTES=5

# ===== CLOUDINARY CONFIGURATION =====
# Sign up at https://cloudinary.com/ to get your credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===== GOOGLE OAUTH2 CONFIGURATION =====
# Create OAuth credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ===== GEMINI AI CONFIGURATION =====
# Get API key from https://makersuite.google.com/app/apikey
# ===== VNPAY PAYMENT CONFIGURATION =====
# Register at https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/v1/payment/vnpay-return

# ===== FILE UPLOAD CONFIGURATION =====
FILE_UPLOAD_DIR=./uploads
FILE_MAX_SIZE=10MB
FILE_BASE_URL=http://localhost:8080/api/v1

# ===== AI SERVICE CONFIGURATION =====
AI_SERVICE_URL=http://localhost:8000
BLACKBOX_API_KEY=your-blackbox-api-key
BLACKBOX_MODEL=blackboxai/google/gemini-2.5-flash
BLACKBOX_API_URL=https://api.blackbox.ai/v1/chat/completions
AI_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_MAX_OUTPUT_TOKENS=1000
AI_SLIDING_WINDOW_SIZE=10
AI_WINDOW_TOKEN_BUDGET=2000

# --- AI Router & Multi-Model ---
AI_ROUTER_MODEL=blackboxai/google/gemini-2.5-flash
AI_MODEL_CHAT=claude-sonnet-4-20250514
AI_MODEL_REASONING=o3-pro
AI_MODEL_KNOWLEDGE=gemini-2.5-pro-preview-05-06
AI_MODEL_IMAGE=imagen-4-ultra

# --- Together.ai Image Generation (Free FLUX model) ---
# Get your free API key at: https://api.together.xyz
TOGETHER_API_KEY=

# --- Hugging Face Image Generation (Free tier, recommended) ---
# Get your free token at: https://huggingface.co/settings/tokens
# Default model: black-forest-labs/FLUX.1-schnell (fast, high quality)
HF_TOKEN=
AI_IMAGE_HF_MODEL=black-forest-labs/FLUX.1-schnell

# --- AI Image Generation ---
# Model to use via Blackbox AI key (recommended: flux-pro, imagen-4, imagen-4-ultra, stable-diffusion-3.5-large)
AI_IMAGE_MODEL=flux-pro
AI_IMAGE_PROVIDER_URL=
AI_IMAGE_API_KEY=
AI_IMAGE_TIMEOUT_MS=45000
AI_IMAGE_READ_URL_EXPIRY_MINUTES=10080
AI_IMAGE_ALLOW_LOCAL_PLACEHOLDER=true
AI_IMAGE_FALLBACK_CONNECT_TIMEOUT_MS=8000
AI_IMAGE_FALLBACK_READ_TIMEOUT_MS=30000
AI_IMAGE_FALLBACK_RETRIES=2
AI_IMAGE_FALLBACK_MAX_DIMENSION=768
AI_IMAGE_FALLBACK_BACKOFF_MS=800

# ===== SERVER CONFIGURATION =====
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api/v1

# ===== CORS CONFIGURATION =====
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== LOGGING CONFIGURATION =====
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG
